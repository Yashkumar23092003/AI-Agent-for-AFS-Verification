# ─────────────────────────────────────────────────────────────────────────────
# LOCAL development environment file.
# Copy this to ".env" and fill in real values. ".env" is gitignored — never commit it.
# For CLOUD deployment, do NOT use this file — use Streamlit Cloud Secrets instead
# (see .streamlit/secrets.toml.example and DEPLOYMENT.md).
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── SMTP (Gmail app password recommended) ────────────────────────────────────
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here

# ── Google Sheets — AFS ↔ Sheet Audit ────────────────────────────────────────
# LOCAL: path to the Google service account JSON key file (relative to project root).
# Share your Google Sheet with the service account's client_email before running.
GOOGLE_SHEETS_CREDENTIALS_PATH=AFS_Verification_GS.json
# CLOUD alternative (instead of a path): paste the full JSON content as one string.
# GOOGLE_SHEETS_CREDENTIALS_JSON={"type":"service_account", ...}

# Optional: pre-fill the Sheet ID in the UI (users can still override it)
DEFAULT_SHEET_ID=1pdRt04-OgUvEQJLXqZXBtZJeYg

# ── Database ─────────────────────────────────────────────────────────────────
# LEAVE UNSET locally → uses the SQLite file kyc_history.db (current behaviour).
# Set this ONLY in the cloud, to your Neon Postgres URL (must end with ?sslmode=require).
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/dbname?sslmode=require
