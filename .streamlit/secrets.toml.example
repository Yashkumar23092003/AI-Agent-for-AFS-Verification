# ─────────────────────────────────────────────────────────────────────────────
# Streamlit Cloud secrets template.
#
# DO NOT put real values in this file. Copy its contents into the Streamlit Cloud
# dashboard:  App  →  Settings  →  Secrets  , and fill in the real values there.
# (Locally you use .env instead — this file is only for the cloud.)
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY = "sk-...your-rotated-key..."

# Gmail SMTP (use a Google App Password, not your real password)
SMTP_EMAIL = "you@gmail.com"
SMTP_PASSWORD = "your-16-char-app-password"

# Neon Postgres connection string (Dashboard → Connection Details → psql/URI)
# Must include ?sslmode=require
DATABASE_URL = "postgresql://USER:PASSWORD@HOST/dbname?sslmode=require"

# Default Google Sheet to pre-fill in the UI
DEFAULT_SHEET_ID = "1pdRt04-OgUvEQJLXqZXBtZJO2Cs7Yg4KwfmW7k7heYg"

# Google service account — paste the ENTIRE JSON key file content as one string.
# In TOML, use triple single-quotes so the embedded JSON quotes/newlines are kept verbatim.
GOOGLE_SHEETS_CREDENTIALS_JSON = '''
{
  "type": "service_account",
  "project_id": "your-project",
  "private_key_id": "...",
  "private_key": "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",
  "client_email": "afs-verification@your-project.iam.gserviceaccount.com",
  "client_id": "...",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token",
  "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
  "client_x509_cert_url": "..."
}
'''
